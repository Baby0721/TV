name: IPTV Auto Sync
on:
  schedule:
    # UTC 19点 = 北京时间 03:00
    - cron: '0 19 * * *'
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo code
        uses: actions/checkout@v4

      - name: Install Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Download source m3u (fail/empty retry)
        run: |
          MAX_RETRY=3
          DELAY=5
          SRC_URL="https://iptv.aiga.cc"
          TMP_M3U="raw.m3u"
          success=0
          for ((i=1; i<=MAX_RETRY; i++)); do
            echo "第 $i 次下载尝试"
            curl -fsSL "$SRC_URL" -o "$TMP_M3U"
            ret=$?
            if [ $ret -eq 0 ] && [ -s "$TMP_M3U" ]; then
              echo "下载成功，文件正常"
              success=1
              break
            fi
            echo "下载失败或空文件，等待${DELAY}s重试"
            sleep $DELAY
          done
          if [ $success -ne 1 ]; then
            echo "多次重试全部失败，退出任务"
            exit 1
          fi
          ls -la

      - name: Process M3U (标准EPG头+中文台标编码)
        run: |
          python3 - <<END
import re
import urllib.parse
import os

raw_file = "raw.m3u"
out_file = "tv.m3u"
logo_base = "https://tvbox.aiga.cc/logo/"
epg_list = [
    "https://snail.aiga.cc/tvbox/iptv-api/epg/epg.gz",
    "https://snail.aiga.cc/tvbox/iptv-api/epg/epg.xml"
]

logo_regex = re.compile(r'(tvg-logo=")([^"]+)(")')

def encode_logo(match):
    pre = match.group(1)
    url = match.group(2)
    suf = match.group(3)
    if url.startswith(logo_base):
        name = url[len(logo_base):]
        safe_name = urllib.parse.quote(name)
        new_url = logo_base + safe_name
        return f"{pre}{new_url}{suf}"
    return match.group(0)

# 读取源文件
with open(raw_file, "r", encoding="utf-8") as f:
    text = f.read()

# 删除第一行旧的 #EXTM3U
text = re.sub(r'^#EXTM3U.*\n', "", text, count=1, flags=re.M)
# 处理台标编码
text = logo_regex.sub(encode_logo, text)
# 拼接标准头部
epg_str = ",".join(epg_list)
header = f'#EXTM3U x-tvg-url="{epg_str}"\n\n'
final_text = header + text

# 输出到根目录 tv.m3u
with open(out_file, "w", encoding="utf-8") as f:
    f.write(final_text)

print("文件处理完成，已生成 tv.m3u")
print("当前目录文件列表:", os.listdir("."))
END

      - name: Commit & Push file
        run: |
          git config --global user.name "IPTV Bot"
          git config --global user.email "bot@aiga.cc"
          git add tv.m3u
          # 检测是否有变更
          if git status --porcelain | grep -q "tv.m3u"; then
            git commit -m "定时更新直播源 $(date '+%Y-%m-%d %H:%M')"
            git push
            echo "tv.m3u 已提交推送"
          else
            echo "tv.m3u 无变化，无需提交"
          fi
